{
  "extends": "next/core-web-vitals",
  "ignorePatterns": [
    ".next/**",
    "node_modules/**",
    "public/**"
  ],
  "rules": {
    // the app directory exports metadata and components together which trips fast
    // refresh rule; disable it globally since it isn't actionable for Next.
    "react-refresh/only-export-components": "off",
    // project uses some `any` conversions for imported data and generic helpers;
    // turning this off avoids dozens of warnings that don't represent real bugs.
    "@typescript-eslint/no-explicit-any": "off"
  }
}
